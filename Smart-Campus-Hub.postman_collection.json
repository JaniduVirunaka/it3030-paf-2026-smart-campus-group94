{
  "info": {
    "name": "Smart Campus Hub API",
    "description": "Complete API collection for the Smart Campus Hub — covers Auth, Resources, Bookings, Tickets, Ticket Comments, and Notifications.\n\nSet the `baseUrl` collection variable to your running backend (default: http://localhost:8080).\n\nRun the **Auth / Login** request first so the session cookie is captured automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:8080",  "type": "string" },
    { "key": "bookingId",  "value": "",                       "type": "string" },
    { "key": "resourceId", "value": "",                       "type": "string" },
    { "key": "ticketId",   "value": "",                       "type": "string" },
    { "key": "commentId",  "value": "",                       "type": "string" },
    { "key": "notifId",    "value": "",                       "type": "string" },
    { "key": "userEmail",  "value": "user@test.com",          "type": "string" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [

        {
          "name": "Register User",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
            "pm.test('success flag is true', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json.success).to.be.true;",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"Password123!\",\n  \"displayName\": \"Test User\",\n  \"registrationNumber\": \"IT21000001\",\n  \"phone\": \"0771234567\"\n}"
            }
          }
        },

        {
          "name": "Register – Duplicate Email (expect 400)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400 Bad Request', () => pm.response.to.have.status(400));",
            "pm.test('Error message present', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json.message).to.include('already in use');",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },

        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
            "pm.test('success flag is true', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json.success).to.be.true;",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },

        {
          "name": "Login – Wrong Password (expect 401)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401 Unauthorized', () => pm.response.to.have.status(401));",
            "pm.test('Error message present', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json.success).to.be.false;",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"wrongpassword\"\n}"
            }
          }
        },

        {
          "name": "Get Current User",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
            "pm.test('authenticated is true', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json.authenticated).to.be.true;",
            "  pm.expect(json.email).to.be.a('string');",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/user"
          }
        },

        {
          "name": "Get Profile",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
            "pm.test('Has email field', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json.email).to.be.a('string');",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/profile"
          }
        },

        {
          "name": "Update Profile",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
            "pm.test('success flag is true', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json.success).to.be.true;",
            "});"
          ]}}],
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/auth/profile",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Updated Name\",\n  \"registrationNumber\": \"IT21000001\",\n  \"phone\": \"0779876543\"\n}"
            }
          }
        }

      ]
    },

    {
      "name": "Resources",
      "item": [

        {
          "name": "Get All Resources",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
            "pm.test('Response has content array', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json.content).to.be.an('array');",
            "  pm.expect(json).to.have.property('totalElements');",
            "});",
            "if (pm.response.json().content.length > 0) {",
            "  pm.collectionVariables.set('resourceId', pm.response.json().content[0].id);",
            "}"
          ]}}],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/resources?searchTerm=&type=ALL&status=ALL&page=0&size=10",
              "query": [
                { "key": "searchTerm", "value": "" },
                { "key": "type",       "value": "ALL" },
                { "key": "status",     "value": "ALL" },
                { "key": "page",       "value": "0" },
                { "key": "size",       "value": "10" }
              ]
            }
          }
        },

        {
          "name": "Get Resources – Search by Name",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
            "pm.test('Results returned', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json.content).to.be.an('array');",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/resources?searchTerm=lab&type=ALL&status=ALL",
              "query": [
                { "key": "searchTerm", "value": "lab" },
                { "key": "type",       "value": "ALL" },
                { "key": "status",     "value": "ALL" }
              ]
            }
          }
        },

        {
          "name": "Create Resource (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
            "pm.test('Resource created with correct name', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json.name).to.eql('API Test Lab');",
            "  pm.expect(json.status).to.eql('ACTIVE');",
            "});",
            "pm.collectionVariables.set('resourceId', pm.response.json().id);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/resources",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"API Test Lab\",\n  \"type\": \"LAB\",\n  \"capacity\": 40,\n  \"location\": \"Block C, Room 301\",\n  \"availabilityWindows\": \"08:00-17:00\",\n  \"status\": \"ACTIVE\"\n}"
            }
          }
        },

        {
          "name": "Create Resource – Validation Error (expect 400)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400 Bad Request', () => pm.response.to.have.status(400));",
            "pm.test('Errors object present', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json.errors).to.be.an('object');",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/resources",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"type\": \"\",\n  \"capacity\": -1,\n  \"location\": \"\",\n  \"availabilityWindows\": \"\",\n  \"status\": \"\"\n}"
            }
          }
