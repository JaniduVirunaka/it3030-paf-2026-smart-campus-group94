        {
          "name": "Get Resource by ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
            "pm.test('Resource ID matches', () => {",
            "  const json = pm.response.json();",
            "  pm.expect(json.id).to.eql(pm.collectionVariables.get('resourceId'));",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/resources/{{resourceId}}"
          }
        },

        {
          "name": "Get Resource by ID – Not Found (expect 404)",
          "event": [{ "listen": "test", "script": { "exec": [
