              "raw": "{\n  \"name\": \"API Test Lab\",\n  \"type\": \"LAB\",\n  \"capacity\": 50,\n  \"location\": \"Block C, Room 301\",\n  \"availabilityWindows\": \"08:00-18:00\",\n  \"status\": \"ACTIVE\"\n}"
            }
